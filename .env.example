# Stripe — clé publique (exposée côté client)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe — clé secrète (fonctions serverless uniquement, JAMAIS côté client)
STRIPE_SECRET_KEY=sk_test_...

# Stripe — secret du webhook (serveur uniquement)
STRIPE_WEBHOOK_SECRET=whsec_...

# Port du serveur Express
PORT=3001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/aerisys

# JWT
JWT_SECRET=change-me-in-production

# Admin seed (utilisé uniquement par npm run seed)
ADMIN_EMAIL=admin@aerisys.fr
ADMIN_PASSWORD=admin123
